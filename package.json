{
	"name": "cached-factory",
	"version": "0.3.0",
	"description": "Creates and caches values under keys. 🏭",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JoshuaKGoldberg/cached-factory.git"
	},
	"license": "MIT",
	"contributors": [
		{
			"name": "JoshuaKGoldberg",
			"email": "npm@joshuakgoldberg.com"
		},
		{
			"name": "michael faith",
			"url": "https://michael.faith"
		}
	],
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./lib/index.js"
	},
